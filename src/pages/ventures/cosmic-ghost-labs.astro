---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/layout/Nav.astro";
import MobileMenu from "../../components/layout/MobileMenu.astro";
---

<BaseLayout
  title="Cosmic Ghost Labs — Experimental Products from the Void"
  description="Cosmic Ghost Labs — experimental products built at the edge of culture and technology."
>
  <Nav />
  <MobileMenu />
  <main
    id="main-content"
    class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-6 text-center"
    style="z-index: 1;"
  >
    <div class="relative z-10 mx-auto max-w-2xl">
      <p
        class="mb-6 font-semibold uppercase tracking-[0.3em] text-[var(--color-text-muted)]"
        style="font-size: var(--text-label);"
      >
        Coming Soon
      </p>

      <h1
        id="cgl-title"
        class="text-reveal font-heading text-[var(--color-text-primary)]"
        style="font-size: var(--text-h2); line-height: var(--text-h2-lh); letter-spacing: -.02em; font-weight: 400;"
      >
        <span class="text-reveal-line">Cosmic Ghost Labs</span>
      </h1>

      <p
        id="cgl-sub"
        class="mx-auto mt-6 max-w-md font-medium text-[var(--color-text-secondary)]"
        style="font-size: var(--text-body); line-height: var(--text-body-lh);"
      >
        Experimental products from the void. We build at the edge of culture and
        technology — shipping things that shouldn't exist yet.
      </p>

      <!-- Email notify CTA -->
      <div id="cgl-cta" class="mt-10 flex flex-col items-center gap-4">
        <form
          id="cgl-notify-form"
          class="flex w-full max-w-sm gap-3"
        >
          <input
            type="email"
            name="email"
            required
            placeholder="your@email.com"
            class="flex-1 border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-5 py-3 text-[var(--color-text-primary)] outline-none transition-colors duration-300 placeholder:text-[var(--color-text-muted)] focus:border-[var(--color-text-primary)]"
            style="font-size: var(--text-sm);"
          />
          <button
            type="submit"
            class="bg-[var(--color-text-primary)] px-6 py-3 font-semibold uppercase tracking-wider text-[var(--color-bg-primary)] transition-all duration-300 hover:opacity-80"
            style="font-size: var(--text-label);"
          >
            Notify Me
          </button>
        </form>
        <p
          id="cgl-notify-success"
          class="hidden text-[var(--color-text-primary)]"
          style="font-size: var(--text-sm);"
        >
          You're on the list. We'll be in touch.
        </p>
      </div>

      <!-- Back link -->
      <a
        href="/"
        class="mt-12 inline-flex items-center gap-2 uppercase tracking-wider text-[var(--color-text-muted)] transition-colors duration-300 hover:text-[var(--color-text-primary)]"
        style="font-size: var(--text-label);"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          class="transition-transform duration-300 hover:-translate-x-0.5"
        >
          <path
            d="M13 7H1M6 2L1 7l5 5"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        Back to Home
      </a>
    </div>
  </main>
</BaseLayout>

<script>
  import gsap from "gsap";

  function initCGL() {
    // Text reveal entrance
    gsap.fromTo(
      ".text-reveal-line",
      { y: "110%", rotateX: -10, opacity: 0 },
      { y: "0%", rotateX: 0, opacity: 1, duration: 0.8, ease: "expo.out", delay: 0.2 }
    );

    gsap.fromTo(
      "#cgl-sub",
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.6, ease: "expo.out", delay: 0.4 }
    );

    gsap.fromTo(
      "#cgl-cta",
      { opacity: 0, y: 15 },
      { opacity: 1, y: 0, duration: 0.5, ease: "expo.out", delay: 0.55 }
    );

    // Notify form
    const form = document.getElementById("cgl-notify-form") as HTMLFormElement | null;
    const successMsg = document.getElementById("cgl-notify-success");
    if (form && successMsg) {
      form.addEventListener("submit", (e) => {
        e.preventDefault();
        gsap.to(form, {
          opacity: 0,
          y: -10,
          duration: 0.3,
          onComplete: () => {
            form.classList.add("hidden");
            successMsg.classList.remove("hidden");
            gsap.fromTo(
              successMsg,
              { opacity: 0, y: 10 },
              { opacity: 1, y: 0, duration: 0.4, ease: "expo.out" }
            );
          },
        });
      });
    }
  }

  initCGL();
  document.addEventListener("astro:after-swap", initCGL);
</script>
