---
import PageLayout from "../layouts/PageLayout.astro";
import SectionLabel from "../components/ui/SectionLabel.astro";
---

<PageLayout
  title="Contact — Nick Scarabosio"
  description="Get in touch with Nick Scarabosio. Book a call, start a project, or just say hello."
>
  <section
    class="mx-auto flex min-h-[80vh] max-w-2xl flex-col items-center justify-center px-6 py-20"
    style="z-index: 1; position: relative;"
  >
    <div id="contact-form-wrapper" class="w-full">
      <div class="mb-10 text-center">
        <SectionLabel class="mb-4">Contact</SectionLabel>
        <h1
          class="text-reveal font-heading text-[var(--color-text-primary)]"
          style="font-size: var(--text-h2); line-height: var(--text-h2-lh); letter-spacing: -.02em; font-weight: 400;"
        >
          <span class="text-reveal-line">Let's talk.</span>
        </h1>
        <p
          class="mt-3 font-medium text-[var(--color-text-secondary)]"
          style="font-size: var(--text-body); line-height: var(--text-body-lh);"
        >
          Have a project, partnership, or idea? Drop a message and I'll get back
          to you.
        </p>
      </div>

      <form
        id="contact-form"
        action="https://formspree.io/f/mjgabqje"
        method="POST"
        class="flex flex-col gap-5"
      >
        <input type="hidden" name="_subject" value="New message from nickscarabosio.com" />

        <div class="grid gap-5 md:grid-cols-2">
          <div class="flex flex-col gap-2">
            <label
              for="firstName"
              class="font-semibold uppercase tracking-wider text-[var(--color-text-secondary)]"
              style="font-size: var(--text-label);"
            >
              First Name
            </label>
            <input
              type="text"
              id="firstName"
              name="firstName"
              required
              autocomplete="given-name"
              class="contact-input border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-4 py-3 text-[var(--color-text-primary)] outline-none transition-colors duration-300 placeholder:text-[var(--color-text-muted)] focus:border-[var(--color-text-primary)]"
              style="font-size: var(--text-base);"
              placeholder="Nick"
            />
          </div>
          <div class="flex flex-col gap-2">
            <label
              for="lastName"
              class="font-semibold uppercase tracking-wider text-[var(--color-text-secondary)]"
              style="font-size: var(--text-label);"
            >
              Last Name
            </label>
            <input
              type="text"
              id="lastName"
              name="lastName"
              required
              autocomplete="family-name"
              class="contact-input border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-4 py-3 text-[var(--color-text-primary)] outline-none transition-colors duration-300 placeholder:text-[var(--color-text-muted)] focus:border-[var(--color-text-primary)]"
              style="font-size: var(--text-base);"
              placeholder="Scarabosio"
            />
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label
            for="email"
            class="font-semibold uppercase tracking-wider text-[var(--color-text-secondary)]"
            style="font-size: var(--text-label);"
          >
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="contact-input border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-4 py-3 text-[var(--color-text-primary)] outline-none transition-colors duration-300 placeholder:text-[var(--color-text-muted)] focus:border-[var(--color-text-primary)]"
            style="font-size: var(--text-base);"
            placeholder="nick@example.com"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label
            for="message"
            class="font-semibold uppercase tracking-wider text-[var(--color-text-secondary)]"
            style="font-size: var(--text-label);"
          >
            Message
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="contact-input resize-none border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-4 py-3 text-[var(--color-text-primary)] outline-none transition-colors duration-300 placeholder:text-[var(--color-text-muted)] focus:border-[var(--color-text-primary)]"
            style="font-size: var(--text-base);"
            placeholder="Tell me about your project or idea..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="mt-2 inline-flex items-center justify-center bg-[var(--color-text-primary)] px-8 py-3.5 font-semibold uppercase tracking-wider text-[var(--color-bg-primary)] transition-all duration-300 hover:opacity-80"
          style="font-size: var(--text-label);"
        >
          Send a Message
        </button>
      </form>
    </div>

    <!-- Success message (hidden by default) -->
    <div
      id="contact-success"
      class="hidden w-full py-20 text-center"
    >
      <div
        class="mb-4 inline-flex h-16 w-16 items-center justify-center border border-[var(--color-text-primary)] text-[var(--color-text-primary)]"
      >
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
          <path
            d="M5 13l4 4L19 7"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>
      <h2
        class="font-heading text-[var(--color-text-primary)]"
        style="font-size: var(--text-h3); line-height: var(--text-h3-lh);"
      >
        Message sent.
      </h2>
      <p
        class="mt-2 font-medium text-[var(--color-text-secondary)]"
        style="font-size: var(--text-body); line-height: var(--text-body-lh);"
      >
        Thanks for reaching out — I'll get back to you soon.
      </p>
    </div>
  </section>
</PageLayout>

<script>
  import gsap from "gsap";

  function initContact() {
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const wrapper = document.getElementById("contact-form-wrapper");
    const success = document.getElementById("contact-success");
    if (!form || !wrapper || !success) return;

    // Text reveal entrance
    gsap.fromTo(
      ".text-reveal-line",
      { y: "110%", rotateX: -10, opacity: 0 },
      { y: "0%", rotateX: 0, opacity: 1, duration: 0.8, ease: "expo.out", delay: 0.1 }
    );

    // Form entrance
    gsap.fromTo(
      wrapper,
      { opacity: 0, y: 30 },
      { opacity: 1, y: 0, duration: 0.8, ease: "expo.out" }
    );

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const data = new FormData(form);

      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: data,
          headers: { Accept: "application/json" },
        });

        if (res.ok) {
          gsap.to(wrapper, {
            opacity: 0,
            y: -20,
            duration: 0.4,
            onComplete: () => {
              wrapper.classList.add("hidden");
              success.classList.remove("hidden");
              gsap.fromTo(
                success,
                { opacity: 0, y: 20 },
                { opacity: 1, y: 0, duration: 0.6, ease: "expo.out" }
              );
            },
          });
        }
      } catch {
        form.submit();
      }
    });
  }

  initContact();
  document.addEventListener("astro:after-swap", initContact);
</script>
