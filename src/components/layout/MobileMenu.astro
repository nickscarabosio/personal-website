---
const links = [
  { label: "About", href: "/#about" },
  { label: "Ventures", href: "/#ventures" },
  { label: "Contact", href: "/contact" },
];
---

<div
  id="mobile-menu"
  class="pointer-events-none fixed inset-0 z-50 flex flex-col items-center justify-center opacity-0 md:hidden"
  style="background-color: var(--color-bg-primary);"
  aria-hidden="true"
>
  <ul class="flex flex-col items-center gap-8">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-menu-link block font-heading opacity-0 transition-opacity duration-300 hover:opacity-70"
            style="font-size: var(--text-h3); line-height: var(--text-h3-lh); color: var(--color-text-primary);"
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<script>
  import gsap from "gsap";

  function initMobileMenu() {
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");
    if (!toggle || !menu) return;

    let isOpen = false;
    const menuLinks = menu.querySelectorAll(".mobile-menu-link");

    const tl = gsap.timeline({ paused: true });
    tl.to(menu, {
      opacity: 1,
      pointerEvents: "auto",
      duration: 0.4,
      ease: "expo.out",
    }).fromTo(
      menuLinks,
      { opacity: 0, y: 40 },
      { opacity: 1, y: 0, stagger: 0.06, duration: 0.6, ease: "expo.out" },
      "-=0.2"
    );

    function openMenu() {
      isOpen = true;
      toggle.classList.add("is-open");
      toggle.setAttribute("aria-expanded", "true");
      menu.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      tl.play();
    }

    function closeMenu() {
      isOpen = false;
      toggle.classList.remove("is-open");
      toggle.setAttribute("aria-expanded", "false");
      menu.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      tl.reverse();
    }

    toggle.addEventListener("click", () => {
      isOpen ? closeMenu() : openMenu();
    });

    menuLinks.forEach((link) => {
      link.addEventListener("click", () => closeMenu());
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen) closeMenu();
    });
  }

  initMobileMenu();
  document.addEventListener("astro:after-swap", initMobileMenu);
</script>
