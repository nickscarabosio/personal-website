---
const pathname = Astro.url.pathname;

const links = [
  { label: "About", href: "/#about" },
  { label: "Ventures", href: "/#ventures" },
  { label: "Contact", href: "/contact" },
];
---

<nav
  id="main-nav"
  aria-label="Main navigation"
  class="fixed top-0 left-0 z-50 flex w-full items-center justify-between px-6 md:px-10"
  style={`height: var(--nav-height); background: linear-gradient(to bottom, var(--color-bg-primary), transparent);`}
>
  <a
    href="/"
    class="font-heading text-[length:var(--text-lg)] tracking-wide text-[var(--color-text-primary)] transition-opacity duration-300 hover:opacity-80"
  >
    Nick Scarabosio
  </a>

  <!-- Desktop links -->
  <ul class="hidden items-center gap-8 md:flex">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "text-[length:var(--text-sm)] font-light tracking-wider uppercase transition-colors duration-300",
              pathname === link.href || (link.href !== "/" && pathname.startsWith(link.href))
                ? "text-[var(--color-accent)]"
                : "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]",
            ]}
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>

  <!-- Mobile hamburger -->
  <button
    id="menu-toggle"
    class="relative z-60 flex h-10 w-10 flex-col items-center justify-center gap-1.5 md:hidden"
    aria-label="Toggle menu"
    aria-expanded="false"
  >
    <span
      class="hamburger-line block h-[1.5px] w-6 bg-[var(--color-text-primary)] transition-all duration-300"
    ></span>
    <span
      class="hamburger-line block h-[1.5px] w-6 bg-[var(--color-text-primary)] transition-all duration-300"
    ></span>
  </button>
</nav>

<style>
  /* Hamburger open state — toggled via JS */
  #menu-toggle.is-open .hamburger-line:first-child {
    transform: translateY(3px) rotate(45deg);
  }
  #menu-toggle.is-open .hamburger-line:last-child {
    transform: translateY(-3px) rotate(-45deg);
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initNav() {
    const nav = document.getElementById("main-nav");
    if (!nav) return;

    // Scroll-aware: add backdrop when scrolled
    ScrollTrigger.create({
      start: "top -80",
      onUpdate: (self) => {
        if (self.direction === 1 && self.scroll() > 80) {
          nav.style.backdropFilter = "blur(12px)";
          nav.style.background = "rgba(10, 10, 10, 0.85)";
        } else if (self.scroll() <= 80) {
          nav.style.backdropFilter = "none";
          nav.style.background =
            "linear-gradient(to bottom, var(--color-bg-primary), transparent)";
        }
      },
    });
  }

  initNav();
  document.addEventListener("astro:after-swap", initNav);
</script>
