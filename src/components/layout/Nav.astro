---
const pathname = Astro.url.pathname;

const links = [
  { label: "About", href: "/#about" },
  { label: "Ventures", href: "/#ventures" },
  { label: "Contact", href: "/contact" },
];
---

<nav
  id="main-nav"
  aria-label="Main navigation"
  class="fixed top-0 left-0 z-50 flex w-full items-center justify-between px-6 md:px-10"
  style="height: var(--nav-height);"
>
  <a
    href="/"
    class="font-heading transition-opacity duration-300 hover:opacity-70"
    style="font-size: var(--text-lg); color: var(--color-text-primary); letter-spacing: .01em;"
  >
    Nick Scarabosio
  </a>

  <!-- Desktop links -->
  <ul class="hidden items-center gap-8 md:flex">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "nav-link relative font-semibold uppercase tracking-wider transition-opacity duration-300",
              pathname === link.href || (link.href !== "/" && pathname.startsWith(link.href))
                ? "text-[var(--color-text-primary)]"
                : "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]",
            ]}
            style="font-size: var(--text-label); line-height: var(--text-label-lh);"
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>

  <!-- Mobile hamburger -->
  <button
    id="menu-toggle"
    class="relative z-60 flex h-10 w-10 flex-col items-center justify-center gap-1.5 md:hidden"
    aria-label="Toggle menu"
    aria-expanded="false"
  >
    <span
      class="hamburger-line block h-[1.5px] w-6 bg-[var(--color-text-primary)] transition-all duration-300"
    ></span>
    <span
      class="hamburger-line block h-[1.5px] w-6 bg-[var(--color-text-primary)] transition-all duration-300"
    ></span>
  </button>
</nav>

<style>
  #main-nav {
    background: transparent;
    transition: background 0.4s cubic-bezier(.16, 1, .3, 1),
                backdrop-filter 0.4s cubic-bezier(.16, 1, .3, 1);
  }

  #main-nav.is-scrolled {
    background: rgba(26, 26, 26, 0.9);
    backdrop-filter: blur(12px);
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 0;
    height: 1px;
    background: var(--color-text-primary);
    transition: width 0.4s cubic-bezier(.16, 1, .3, 1);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  #menu-toggle.is-open .hamburger-line:first-child {
    transform: translateY(3px) rotate(45deg);
  }
  #menu-toggle.is-open .hamburger-line:last-child {
    transform: translateY(-3px) rotate(-45deg);
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initNav() {
    const nav = document.getElementById("main-nav");
    if (!nav) return;

    ScrollTrigger.create({
      start: "top -80",
      onUpdate: (self) => {
        if (self.scroll() > 80) {
          nav.classList.add("is-scrolled");
        } else {
          nav.classList.remove("is-scrolled");
        }
      },
    });
  }

  initNav();
  document.addEventListener("astro:after-swap", initNav);
</script>
