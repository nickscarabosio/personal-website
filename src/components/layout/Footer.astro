---
const year = new Date().getFullYear();
---

<footer
  class="flex flex-col items-center justify-between gap-4 border-t px-6 py-8 md:flex-row md:px-10"
  style="border-color: var(--color-border); z-index: 1; position: relative;"
>
  <p
    class="font-medium text-[var(--color-text-muted)]"
    style="font-size: var(--text-label); line-height: var(--text-label-lh);"
  >
    &copy; {year} Nick Scarabosio
  </p>

  <div class="flex items-center gap-6">
    <a
      href="https://twitter.com"
      target="_blank"
      rel="noopener noreferrer"
      class="font-medium uppercase tracking-wider text-[var(--color-text-muted)] transition-opacity duration-300 hover:text-[var(--color-text-primary)]"
      style="font-size: var(--text-label); line-height: var(--text-label-lh);"
    >
      Twitter
    </a>
    <a
      href="https://linkedin.com"
      target="_blank"
      rel="noopener noreferrer"
      class="font-medium uppercase tracking-wider text-[var(--color-text-muted)] transition-opacity duration-300 hover:text-[var(--color-text-primary)]"
      style="font-size: var(--text-label); line-height: var(--text-label-lh);"
    >
      LinkedIn
    </a>
  </div>
</footer>
