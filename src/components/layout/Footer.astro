---
const year = new Date().getFullYear();
---

<footer
  class="flex flex-col items-center justify-between gap-4 border-t px-6 py-8 md:flex-row md:px-10"
  style="border-color: var(--color-border);"
>
  <p
    class="text-[length:var(--text-xs)] font-light text-[var(--color-text-muted)]"
  >
    &copy; {year} Nick Scarabosio. All rights reserved.
  </p>

  <div class="flex items-center gap-6">
    <a
      href="https://twitter.com"
      target="_blank"
      rel="noopener noreferrer"
      class="text-[length:var(--text-xs)] font-light uppercase tracking-wider text-[var(--color-text-muted)] transition-colors duration-300 hover:text-[var(--color-text-primary)]"
    >
      Twitter
    </a>
    <a
      href="https://linkedin.com"
      target="_blank"
      rel="noopener noreferrer"
      class="text-[length:var(--text-xs)] font-light uppercase tracking-wider text-[var(--color-text-muted)] transition-colors duration-300 hover:text-[var(--color-text-primary)]"
    >
      LinkedIn
    </a>
  </div>
</footer>
