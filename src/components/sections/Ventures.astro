---
import { getCollection } from "astro:content";
import SectionLabel from "../ui/SectionLabel.astro";
import VentureCard from "../ui/VentureCard.astro";

const ventures = await getCollection("ventures");
---

<section
  id="ventures"
  class="mx-auto max-w-[var(--max-width)] px-6 md:px-10"
  style="padding-top: var(--space-section); padding-bottom: var(--space-section); z-index: 1; position: relative;"
>
  <div class="mb-12 text-center">
    <SectionLabel class="mb-4">Ventures</SectionLabel>
    <h2
      class="text-reveal font-heading text-[var(--color-text-primary)]"
      style="font-size: var(--text-h2); line-height: var(--text-h2-lh); letter-spacing: -.02em; font-weight: 400;"
    >
      <span class="text-reveal-line">What I'm Building</span>
    </h2>
  </div>

  <div class="grid gap-6 md:grid-cols-3">
    {
      ventures.map((v) => (
        <VentureCard
          name={v.data.name}
          descriptor={v.data.descriptor}
          status={v.data.status}
          url={v.data.url}
          urlLabel={v.data.urlLabel}
          internal={v.data.internal}
        />
      ))
    }
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initVentures() {
    // Heading reveal
    gsap.fromTo(
      "#ventures .text-reveal-line",
      { y: "110%", rotateX: -10, opacity: 0 },
      {
        y: "0%",
        rotateX: 0,
        opacity: 1,
        duration: 0.8,
        ease: "expo.out",
        scrollTrigger: {
          trigger: "#ventures",
          start: "top 80%",
          once: true,
        },
      }
    );

    // Card stagger
    gsap.fromTo(
      ".venture-card",
      { opacity: 0, y: 40 },
      {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.12,
        ease: "expo.out",
        scrollTrigger: {
          trigger: "#ventures .grid",
          start: "top 85%",
          once: true,
        },
      }
    );
  }

  initVentures();
  document.addEventListener("astro:after-swap", initVentures);
</script>
