---
import Button from "../ui/Button.astro";
---

<section
  id="hero"
  class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-6 text-center"
  style="z-index: 1;"
>
  <div class="relative z-10 flex flex-col items-center gap-6" style="max-width: 90vw;">
    <p
      id="hero-meta"
      class="text-[length:var(--text-label)] font-semibold uppercase tracking-[0.25em] text-[var(--color-text-muted)] opacity-0"
      style="line-height: var(--text-label-lh);"
    >
      Operator &middot; Coach &middot; Builder
    </p>

    <h1
      id="hero-name"
      class="text-reveal font-heading"
      style="font-size: var(--text-h1); line-height: var(--text-h1-lh); letter-spacing: -.02em; font-weight: 400;"
    >
      <span class="text-reveal-line">Nick</span>
      <span class="text-reveal-line">Scarabosio</span>
    </h1>

    <p
      id="hero-sub"
      class="max-w-lg font-medium text-[var(--color-text-secondary)] opacity-0"
      style="font-size: var(--text-body); line-height: var(--text-body-lh);"
    >
      Building ventures, coaching creators, and shipping products that move
      culture forward.
    </p>

    <div id="hero-cta" class="mt-6 flex items-center gap-4 opacity-0">
      <Button href="/contact">Book a Call</Button>
      <Button href="/#ventures" variant="ghost">See Ventures</Button>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    id="hero-scroll-indicator"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0"
  >
    <div class="animate-scroll-pulse flex flex-col items-center gap-2">
      <span
        class="text-[length:var(--text-xs)] uppercase tracking-widest text-[var(--color-text-muted)]"
        >Scroll</span
      >
      <svg
        width="16"
        height="24"
        viewBox="0 0 16 24"
        fill="none"
        class="text-[var(--color-text-muted)]"
      >
        <path
          d="M8 4L8 20M8 20L14 14M8 20L2 14"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";

  function initHero() {
    const ease = "expo.out";

    // Text reveal — slide up with rotateX
    gsap.fromTo(
      ".text-reveal-line",
      {
        y: "110%",
        rotateX: -10,
        opacity: 0,
      },
      {
        y: "0%",
        rotateX: 0,
        opacity: 1,
        duration: 1,
        stagger: 0.15,
        ease,
        delay: 0.2,
      }
    );

    // Meta line
    gsap.fromTo(
      "#hero-meta",
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.6, ease, delay: 0.1 }
    );

    // Subtitle
    gsap.fromTo(
      "#hero-sub",
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.6, ease, delay: 0.5 }
    );

    // CTA buttons
    gsap.fromTo(
      "#hero-cta",
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.6, ease, delay: 0.65 }
    );

    // Scroll indicator
    gsap.fromTo(
      "#hero-scroll-indicator",
      { opacity: 0 },
      { opacity: 1, duration: 0.8, ease, delay: 1.2 }
    );
  }

  initHero();
  document.addEventListener("astro:after-swap", initHero);
</script>
