---
interface Props {
  name: string;
  descriptor: string;
  status: "active" | "coming-soon";
  url?: string;
  urlLabel?: string;
  internal?: boolean;
}

const { name, descriptor, status, url, urlLabel, internal } = Astro.props;

const isActive = status === "active";
const Tag = url ? "a" : "div";
const linkProps = url
  ? {
      href: url,
      ...(internal ? {} : { target: "_blank", rel: "noopener noreferrer" }),
    }
  : {};
---

<Tag
  {...linkProps}
  class:list={[
    "venture-card group relative flex flex-col justify-between gap-6 border p-6 transition-all duration-300 md:p-8",
    isActive
      ? "border-[var(--color-border)] bg-[var(--color-bg-secondary)] hover:-translate-y-1 hover:border-[var(--color-border-hover)]"
      : "border-[var(--color-border)] bg-[var(--color-bg-secondary)] opacity-50",
  ]}
>
  <div>
    <div class="mb-2 flex items-center gap-3">
      <h3
        class="font-heading text-[var(--color-text-primary)]"
        style="font-size: var(--text-h3); line-height: var(--text-h3-lh); letter-spacing: -.02em;"
      >
        {name}
      </h3>
      {
        !isActive && (
          <span
            class="bg-[var(--color-bg-tertiary)] px-3 py-1 font-semibold text-[var(--color-text-muted)]"
            style="font-size: var(--text-label);"
          >
            Coming Soon
          </span>
        )
      }
    </div>
    <p
      class="font-medium text-[var(--color-text-secondary)]"
      style="font-size: var(--text-sm);"
    >
      {descriptor}
    </p>
  </div>

  {
    urlLabel && (
      <span
        class:list={[
          "inline-flex items-center gap-1 font-semibold uppercase tracking-wider transition-opacity duration-300",
          isActive
            ? "text-[var(--color-text-primary)] group-hover:opacity-70"
            : "text-[var(--color-text-muted)]",
        ]}
        style="font-size: var(--text-label);"
      >
        {urlLabel}
        <svg
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          class="transition-transform duration-300 group-hover:translate-x-0.5"
        >
          <path
            d="M1 7h12M8 2l5 5-5 5"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </span>
    )
  }
</Tag>
