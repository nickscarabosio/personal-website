---
interface Props {
  href?: string;
  variant?: "primary" | "ghost";
  class?: string;
  [key: string]: any;
}

const { href, variant = "primary", class: className, ...rest } = Astro.props;

const Tag = href ? "a" : "button";

const baseClasses =
  "inline-flex items-center justify-center gap-2 px-6 py-3 font-semibold uppercase tracking-wider transition-all duration-300";

const variantClasses = {
  primary:
    "bg-[var(--color-text-primary)] text-[var(--color-bg-primary)] hover:opacity-80",
  ghost:
    "border border-[var(--color-border)] text-[var(--color-text-primary)] hover:border-[var(--color-text-primary)]",
};
---

<Tag
  href={href}
  class:list={[baseClasses, variantClasses[variant], className]}
  style="font-size: var(--text-label); line-height: var(--text-label-lh);"
  {...rest}
>
  <slot />
</Tag>
