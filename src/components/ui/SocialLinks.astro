---
interface Props {
  class?: string;
  id?: string;
}

const { class: className, id } = Astro.props;

const socials = [
  { label: "Twitter", href: "https://twitter.com", icon: "𝕏" },
  { label: "LinkedIn", href: "https://linkedin.com", icon: "in" },
];
---

<div class:list={["flex items-center gap-4", className]} id={id}>
  {
    socials.map((s) => (
      <a
        href={s.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={s.label}
        class="flex h-10 w-10 items-center justify-center border border-[var(--color-border)] text-[var(--color-text-secondary)] transition-all duration-300 hover:border-[var(--color-text-primary)] hover:text-[var(--color-text-primary)]"
        style="font-size: var(--text-sm);"
      >
        {s.icon}
      </a>
    ))
  }
</div>
