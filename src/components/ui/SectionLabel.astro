---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<span
  class:list={[
    "inline-block font-semibold uppercase tracking-[0.2em] text-[var(--color-text-muted)]",
    className,
  ]}
  style="font-size: var(--text-label); line-height: var(--text-label-lh);"
>
  <slot />
</span>
